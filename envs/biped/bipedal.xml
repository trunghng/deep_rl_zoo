<mujoco model="bipedal">
    <compiler angle="degree" coordinate="local"/>

    <default>
        <joint limited="true" armature="0.01" damping="0.5"/>
        <default class="hip_x"> <!-- side-to-side -->
            <joint axis="1 0 0" range="-20 20"/>
        </default>
        <default class="hip_z"> <!-- twist -->
            <joint axis="0 0 1" range="-30 30"/>
        </default>
        <default class="hip_y"> <!-- forward/backward -->
            <joint axis="0 1 0" range="-60 60"/>
        </default>
        <default class="hip">
            <geom type="sphere" size=".04"/>
        </default>
        <default class="thigh">
            <geom type="cylinder" size=".03"/>
        </default>
        <default class="knee">
            <joint axis="0 1 0" range="0 100"/>
            <geom type="cylinder" size=".04"/>
        </default>
        <default class="lower_leg">
            <geom type="cylinder" size=".01"/>
        </default>
        <default class="ankle_x">
            <joint axis="1 0 0" range="-20 20"/>
        </default>
        <default class="ankle_y">
            <joint axis="0 1 0" range="-50 30"/>
        </default>
        <default class="ankle">
            <geom type="cylinder" size=".02"/>
        </default>
        <default class="foot">
            <geom type="box" size=".08 .05 .01"/>
            <site type="box" size=".08 .05 .01" rgba="1 0 0 0"/>
        </default>
        <default class="motor">
            <motor ctrlrange="-1 1" ctrllimited="true"/>
        </default>
    </default>

    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3"
            rgb2=".2 .3 .4" width="300" height="300"/>
        <material name="grid" texture="grid" texrepeat="8 8" reflectance=".2"/>
    </asset>

    <worldbody>
        <geom name="floor" size="10 10 .05" type="plane" material="grid"/>
        <light pos="0 0 10" dir="0 0 -1"/>
        <body name="torso" pos="0 0 1.2">
            <freejoint name="root"/>
            <geom name="torso_geom" type="box" size=".2 .2 .15"/>
            <body name="pelvis" pos="0 0 -.3">
                <geom name="pelvis_geom" type="cylinder" fromto="0 -.11 0 0 .11 0" size=".03"/>
                <body name="thigh_left" pos="0 .2 0 ">
                    <joint name="hip_x_left" class="hip_x"/>
                    <joint name="hip_z_left" class="hip_z"/>
                    <joint name="hip_y_left" class="hip_y"/>
                    <geom name="hip_left" pos="0 -.04 0" class="hip"/>
                    <geom name="thigh_left" fromto="0 -.04 -.05 0 -.04 -.35" class="thigh"/>
                    <body name="lower_leg_left" pos="0 0 -.4">
                        <joint name="knee_left" class="knee"/>
                        <geom name="knee_left_geom" fromto="0 0 0 0 -.08 0" class="knee"/>
                        <geom name="lower_leg_left" fromto="0 -.04 -.05 0 -.04 -.4" class="lower_leg"/>
                        <body name="foot_left" pos="0 0 -.41">
                            <joint name="ankle_x_left" class="ankle_x"/>
                            <joint name="ankle_y_left" class="ankle_y"/>
                            <geom name="ankle1_left" fromto="-.04 -.04 -.02 .04 -.04 -.02" class="ankle"/>
                            <geom name="ankle2_left" fromto="0 -.005 -.02 0 -.075 -.02" class="ankle"/>
                            <geom name="foot_left" pos=".03 -.04 -.05" class="foot"/>
                            <site name="foot_left_site" pos=".03 -.04 -.05" class="foot"/>
                        </body>
                    </body>
                </body>

                <body name="thigh_right" pos="0 -.2 0">
                    <joint name="hip_x_right" class="hip_x"/>
                    <joint name="hip_z_right" class="hip_z"/>
                    <joint name="hip_y_right" class="hip_y"/>
                    <geom name="hip_right" pos="0 .04 0" class="hip"/>
                    <geom name="thigh_right" fromto="0 .04 -.05 0 .04 -.35" class="thigh"/>
                    <body name="lower_leg_right" pos="0 0 -.4">
                        <joint name="knee_right" class="knee"/>
                        <geom name="knee_right_geom" fromto="0 0 0 0 .08 0" class="knee"/>
                        <geom name="lower_leg_right" fromto="0 .04 -.05 0 .04 -.4" class="lower_leg"/>
                        <body name="foot_right" pos="0 0 -.41">
                            <joint name="ankle_x_right" class="ankle_x"/>
                            <joint name="ankle_y_right" class="ankle_y"/>
                            <geom name="ankle1_right" fromto="-.04 .04 -.02 .04 .04 -.02" class="ankle"/>
                            <geom name="ankle2_right" fromto="0 .005 -.02 0 .075 -.02" class="ankle"/>
                            <geom name="foot_right" pos=".03 .04 -.05" class="foot"/>
                            <site name="foot_right_site" pos=".03 .04 -.05" class="foot"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="hip_x_left" joint="hip_x_left" gear="40" class="motor"/>
        <motor name="hip_z_left" joint="hip_z_left" gear="40" class="motor"/>
        <motor name="hip_y_left" joint="hip_y_left" gear="120" class="motor"/>
        <motor name="knee_left"  joint="knee_left"  gear="80" class="motor"/>
        <motor name="ankle_x_left" joint="ankle_x_left" gear="20" class="motor"/>
        <motor name="ankle_y_left" joint="ankle_y_left" gear="20" class="motor"/>

        <motor name="hip_x_right" joint="hip_x_right" gear="40" class="motor"/>
        <motor name="hip_z_right" joint="hip_z_right" gear="40" class="motor"/>
        <motor name="hip_y_right" joint="hip_y_right" gear="120" class="motor"/>
        <motor name="knee_right"  joint="knee_right"  gear="80" class="motor"/>
        <motor name="ankle_x_right" joint="ankle_x_right" gear="20" class="motor"/>
        <motor name="ankle_y_right" joint="ankle_y_right" gear="20" class="motor"/>
    </actuator>

    <sensor>
        <touch name="touch_left" site="foot_left_site"/>
        <touch name="touch_right" site="foot_right_site"/>
    </sensor>
</mujoco>